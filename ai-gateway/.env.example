# En az 32 karakterlik rastgele bir değer kullanın. Bu değeri Nexus ana sunucusundaki
# OLLAMA_API_KEY ile aynı yapın.
AI_GATEWAY_API_KEY=replace-with-a-long-random-secret

# Yalnızca Nexus ana sunucusunun Tailscale IP'sini /32 olarak ekleyin.
# Örnek: 100.80.0.10/32 (gerçek arkadaş-PC Tailscale IP'siyle değiştirin)
AI_GATEWAY_ALLOWED_NETWORKS=127.0.0.1/32,::1/128,100.80.0.10/32

# Gateway güvenilir bir reverse proxy arkasındaysa proxy IP/CIDR'sini buraya yazın.
# Boşken X-Forwarded-For başlığı tamamen yok sayılır.
AI_GATEWAY_TRUSTED_PROXIES=

# Gateway host üzerinde çalışıyorsa:
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CONNECT_TIMEOUT_SECONDS=5
OLLAMA_READ_TIMEOUT_SECONDS=120
AI_GATEWAY_MAX_REQUEST_BYTES=1048576
