# PostgreSQL
POSTGRES_USER=nexus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nexus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Core API
CORE_API_SECRET_KEY=changeme

# Matrix Synapse
MATRIX_SERVER_NAME=nexus.local
MATRIX_HOMESERVER_URL=http://localhost:8008
# matrix/synapse/homeserver.yaml içindeki registration_shared_secret ile aynı olmalı
MATRIX_REGISTRATION_SHARED_SECRET=changeme

# Ollama (AI işlem sunucusu) - hibrit mimaride uzak bir makineye işaret edebilir,
# ör. http://ai-server.local:11434. Ücretsiz/yerel; API anahtarı Ollama'nın kendisi
# için gerekmez, sadece araya bir gateway/reverse-proxy konursa kullanılır.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
