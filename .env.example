# PostgreSQL
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=replace-with-a-random-admin-password
POSTGRES_USER=nexus
POSTGRES_PASSWORD=replace-with-a-random-nexus-password
POSTGRES_DB=nexus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Synapse PostgreSQL (aynı postgres container'ında ayrı kullanıcı/veritabanı)
SYNAPSE_POSTGRES_USER=synapse
SYNAPSE_POSTGRES_PASSWORD=replace-with-a-random-synapse-password
SYNAPSE_POSTGRES_DB=synapse

# Core API
CORE_API_SECRET_KEY=replace-with-a-long-random-jwt-secret

# Public reverse proxy
NEXUS_DOMAIN=nexus.example.com
NEXUS_ACME_EMAIL=admin@example.com
NEXUS_HTTP_PORT=80
NEXUS_HTTPS_PORT=443
# LAN-only development override for the host mentioned in TASK-012:
# NEXUS_DOMAIN=192.168.1.174

# Matrix Synapse
MATRIX_SERVER_NAME=nexus.example.com
# LAN-only development override (keep aligned with NEXUS_DOMAIN):
# MATRIX_SERVER_NAME=192.168.1.174
MATRIX_HOMESERVER_URL=http://localhost:8008
MATRIX_REGISTRATION_SHARED_SECRET=replace-with-a-long-random-registration-secret
MATRIX_MACAROON_SECRET_KEY=replace-with-a-long-random-macaroon-secret
MATRIX_FORM_SECRET=replace-with-a-long-random-form-secret

# Ollama (AI işlem sunucusu) - hibrit mimaride uzak bir makineye işaret edebilir,
# Tailscale üzerinden AI Gateway. Doğrudan Ollama :11434 adresini kullanmayın.
# API anahtarı Ollama'nın kendisi için değil, ai-gateway servisi için kullanılır.
OLLAMA_BASE_URL=http://100.90.0.20:8090
OLLAMA_API_KEY=replace-with-the-ai-gateway-api-key
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_CONNECT_TIMEOUT_SECONDS=5
OLLAMA_READ_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_BACKOFF_SECONDS=0.5
OLLAMA_MODEL_CACHE_SECONDS=30

# AI Worker (TASK-007)
AI_WORKER_POLL_SECONDS=0.5
AI_WORKER_LEASE_SECONDS=300
AI_WORKER_MAX_ATTEMPTS=3
AI_WORKER_RETRY_BACKOFF_SECONDS=2.0
AI_MAX_PENDING_JOBS_PER_USER=20
AI_CONTEXT_TOKEN_BUDGET=3072
AI_MAX_OUTPUT_TOKENS=1024
AI_STREAM_POLL_SECONDS=0.15

# Plugin sandbox (TASK-010). Keep local mode only for development.
PLUGIN_EXECUTION_MODE=sandbox
PLUGIN_SANDBOX_URL=http://plugin-sandbox:8091
PLUGIN_SANDBOX_API_KEY=replace-with-a-long-random-plugin-sandbox-key
PLUGIN_SANDBOX_TIMEOUT_SECONDS=10
PLUGIN_SANDBOX_MAX_PAYLOAD_BYTES=65536
PLUGIN_SANDBOX_MAX_OUTPUT_BYTES=65536

# WebRTC TURN relay (TASK-011). TURN_EXTERNAL_IP is the host's public IP.
TURN_DOMAIN=nexus.example.com
TURN_PORT=3478
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
TURN_EXTERNAL_IP=203.0.113.10
TURN_AUTH_SECRET=replace-with-a-long-random-turn-auth-secret
TURN_CREDENTIAL_TTL_SECONDS=3600
# LAN-only override: set TURN_DOMAIN and TURN_EXTERNAL_IP to 192.168.1.174.
